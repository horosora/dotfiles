"----------------------------
" 表示設定
"----------------------------

" 行番号を表示
set number

" タイトルを表示
set title

" オートインデントを有効
set autoindent

" tabの表示幅
set tabstop=4

" オートインデントでのtab幅
set shiftwidth=4

" ソフトtabを有効
set expandtab


"----------------------------
" 検索設定
"----------------------------

" 検索語をハイライト表示
set wrapscan


"----------------------------
" その他
"----------------------------

" スワップファイルを作らない
set noswapfile
